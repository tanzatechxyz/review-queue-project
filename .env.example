APP_HOST=0.0.0.0
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
APP_DB_PATH=/data/review_queue.db
APP_ROOT_FOLDER=/videos
APP_DATA_DIR=/data
APP_SUPPORTED_EXTENSIONS=.mp4,.mov,.m4v,.webm,.mkv
APP_WATCHED_THRESHOLD_PERCENT=95
APP_SORT_PRIORITY=filename,metadata,filesystem
APP_AUTO_ADVANCE_ON_DONE=true
APP_AUTO_ADVANCE_ON_END=true
APP_GENERATE_THUMBNAILS=false
APP_THUMBNAIL_INTERVAL_SECONDS=3
APP_THUMBNAIL_WIDTH=480
APP_AUTH_ENABLED=false
APP_USERNAME=admin
APP_PASSWORD=changeme
APP_SECRET_KEY=change-this-in-production
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:8080
APP_AUTO_SCAN_ON_STARTUP=true
APP_SCAN_ON_SETTINGS_SAVE=false
